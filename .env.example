# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
STRIPE_APP_URL=https://www.stormclose.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_ENTERPRISE=price_xxx

# OpenAI
OPENAI_API_KEY=sk-proj-xxx
OPENAI_MODEL=gpt-4o-mini

# Weather and property data providers
XWEATHER_CLIENT_ID=your-xweather-client-id
XWEATHER_CLIENT_SECRET=your-xweather-client-secret
CORELOGIC_CONSUMER_KEY=your-corelogic-consumer-key
CORELOGIC_CONSUMER_SECRET=your-corelogic-consumer-secret

# Google APIs
# Server-side API key for Directions, Geocoding, Places, etc.
GOOGLE_MAPS_API_KEY=your-google-maps-server-key
# Browser-embedded map key (restrict by HTTP referrer)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-embed-key
# Solar/vision routes
GOOGLE_SOLAR_API_KEY=your-google-solar-api-key

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# Scheduled jobs (Vercel cron authorization)
CRON_SECRET=replace-with-a-long-random-secret

# JobNimbus integration (required for CRM sync)
JOBNIMBUS_ENCRYPTION_KEY=replace-with-32-char-hex-key-for-api-key-encryption
JOBNIMBUS_WEBHOOK_SECRET=replace-with-jobnimbus-webhook-secret
JOBNIMBUS_WEBHOOK_URL=https://your-app.vercel.app/api/jobnimbus/webhook

# Storm provider integrations (HailTrace, HailRecon)
STORM_PROVIDER_ENCRYPTION_KEY=replace-with-32-char-hex-key-for-credentials
HAILTRACE_API_BASE_URL=https://developers.hailtrace.com/api/external

# Email (Resend) - demo requests, team invites
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=StormClose <noreply@stormclose.com>
DEMO_REQUEST_EMAIL=support@stormclose.com

# Optional: dev helpers
DEV_AUTO_CONFIRM_SIGNUPS=false
ENABLE_DEBUG_ENDPOINTS=false

# Stripe LIVE mode (put real keys in .env.local or Vercel - never commit)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx  (from Stripe Dashboard → Webhooks → Live endpoint)
# STRIPE_PRICE_ID_PRO=price_xxx
# STRIPE_PRICE_ID_ENTERPRISE=price_xxx