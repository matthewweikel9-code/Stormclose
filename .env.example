# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
STRIPE_APP_URL=https://www.stormclose.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_PRO_PLUS=price_xxx
STRIPE_PRICE_ID_ENTERPRISE=price_xxx

# OpenAI
OPENAI_API_KEY=sk-proj-xxx
OPENAI_MODEL=gpt-4o-mini

# Weather and property data providers
XWEATHER_CLIENT_ID=your-xweather-client-id
XWEATHER_CLIENT_SECRET=your-xweather-client-secret
CORELOGIC_CONSUMER_KEY=your-corelogic-consumer-key
CORELOGIC_CONSUMER_SECRET=your-corelogic-consumer-secret

# Google APIs
# Server-side API key for Directions, Geocoding, Places, etc.
GOOGLE_MAPS_API_KEY=your-google-maps-server-key
# Browser-embedded map key (restrict by HTTP referrer)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-embed-key
# Solar/vision routes
GOOGLE_SOLAR_API_KEY=your-google-solar-api-key

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# Scheduled jobs (Vercel cron authorization)
CRON_SECRET=replace-with-a-long-random-secret

# JobNimbus webhook verification
JOBNIMBUS_WEBHOOK_SECRET=replace-with-jobnimbus-webhook-secret
